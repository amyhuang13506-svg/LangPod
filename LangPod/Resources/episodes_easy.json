    "title": "AI Fitness App",
    "level": "easy",
    "date": "2026-03-29",
    "duration_seconds": 23,
    "script": [
      {
        "speaker": "Alex",
        "text": "Hi Lisa! Have you heard about the new app?",
        "translation_zh": "嗨 Lisa！你听说过这个新应用吗？",
        "emotion": "neutral",
        "start": 0.0,
        "end": 3.67
      },
      {
        "speaker": "Lisa",
        "text": "Yes, it is very popular now.",
        "translation_zh": "是的，它现在非常受欢迎。",
        "emotion": "happy",
        "start": 4.47,
        "end": 7.62
      },
      {
        "speaker": "Alex",
        "text": "It helps people exercise with AI.",
        "translation_zh": "它帮助人们通过人工智能锻炼。",
        "emotion": "neutral",
        "start": 8.41,
        "end": 11.34
      },
      {
        "speaker": "Lisa",
        "text": "That's great! I want to try it.",
        "translation_zh": "太好了！我想试试。",
        "emotion": "happy",
        "start": 12.14,
        "end": 15.29
      },
      {
        "speaker": "Alex",
        "text": "OK, let's download it together later.",
        "translation_zh": "好的，我们稍后一起下载。",
        "emotion": "happy",
        "start": 16.09,
        "end": 19.65
      },
      {
        "speaker": "Lisa",
        "text": "Sure! Thanks for telling me.",
        "translation_zh": "当然！谢谢你告诉我。",
        "emotion": "happy",
        "start": 20.45,
        "end": 23.21
      }
    ],
