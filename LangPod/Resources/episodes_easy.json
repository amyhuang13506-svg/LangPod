  {
    "id": "ep-2026-0327-easy-003",
    "title": "The Weather",
    "level": "easy",
    "date": "2026-03-27",
    "duration_seconds": 190,
    "audio": {
      "english": "https://oss.langpod.com/episodes/easy-003/en.mp3",
      "translation_zh": "https://oss.langpod.com/episodes/easy-003/zh.mp3"
    },
    "script": [
      {
        "speaker": "Alex",
        "text": "It's really cold today, isn't it?",
        "start": 0.0,
        "end": 2.5,
        "translation_zh": "今天真的很冷，对吧？"
      },
      {
        "speaker": "Lisa",
        "text": "Yes! I think it might rain later.",
        "start": 2.8,
        "end": 5.5,
        "translation_zh": "是啊！我觉得一会儿可能会下雨。"
      },
      {
        "speaker": "Alex",
        "text": "Did you bring an umbrella?",
        "start": 5.8,
        "end": 7.8,
        "translation_zh": "你带伞了吗？"
      },
      {
        "speaker": "Lisa",
        "text": "No, I forgot. I hope it doesn't rain too hard.",
        "start": 8.0,
        "end": 11.5,
        "translation_zh": "没有，我忘了。希望不会下太大。"
      },
      {
        "speaker": "Alex",
        "text": "The forecast says it will be sunny tomorrow.",
        "start": 11.8,
        "end": 14.8,
        "translation_zh": "天气预报说明天会是晴天。"
      },
      {
        "speaker": "Lisa",
        "text": "That's great. I want to go to the park.",
        "start": 15.0,
        "end": 17.5,
        "translation_zh": "太好了。我想去公园。"
      }
    ],
    "vocabulary": [
      {
        "word": "weather",
        "phonetic": "/ˈweðər/",
        "translation_zh": "天气",
        "example": "The weather is nice today.",
        "audio": "https://oss.langpod.com/words/weather.mp3"
      },
      {
        "word": "umbrella",
        "phonetic": "/ʌmˈbrelə/",
        "translation_zh": "雨伞",
        "example": "Take an umbrella with you.",
        "audio": "https://oss.langpod.com/words/umbrella.mp3"
      },
      {
        "word": "forecast",
        "phonetic": "/ˈfɔːrkæst/",
        "translation_zh": "预报",
        "example": "Check the weather forecast.",
        "audio": "https://oss.langpod.com/words/forecast.mp3"
      },
      {
        "word": "sunny",
        "phonetic": "/ˈsʌni/",
        "translation_zh": "晴朗的",
        "example": "It's a sunny day.",
        "audio": "https://oss.langpod.com/words/sunny.mp3"
      },
      {
        "word": "forgot",
        "phonetic": "/fərˈɡɑːt/",
        "translation_zh": "忘记了（forget的过去式）",
        "example": "I forgot my keys.",
        "audio": "https://oss.langpod.com/words/forgot.mp3"
      }
    ]
  }
