  {
    "id": "ep-2026-0326-easy-002",
    "title": "At the Store",
    "level": "easy",
    "date": "2026-03-26",
    "duration_seconds": 200,
    "audio": {
      "english": "https://oss.langpod.com/episodes/easy-002/en.mp3",
      "translation_zh": "https://oss.langpod.com/episodes/easy-002/zh.mp3"
    },
    "script": [
      {
        "speaker": "Alex",
        "text": "Excuse me, how much is this?",
        "start": 0.0,
        "end": 2.2,
        "translation_zh": "不好意思，这个多少钱？"
      },
      {
        "speaker": "Lisa",
        "text": "That one is five dollars.",
        "start": 2.5,
        "end": 4.5,
        "translation_zh": "那个五美元。"
      },
      {
        "speaker": "Alex",
        "text": "Do you have a smaller size?",
        "start": 4.8,
        "end": 6.8,
        "translation_zh": "有小一点的尺码吗？"
      },
      {
        "speaker": "Lisa",
        "text": "Let me check. Yes, we have small and medium.",
        "start": 7.0,
        "end": 10.5,
        "translation_zh": "我查一下。有的，我们有小号和中号。"
      },
      {
        "speaker": "Alex",
        "text": "I'll take the small one, please.",
        "start": 10.8,
        "end": 13.0,
        "translation_zh": "请给我小号的。"
      },
      {
        "speaker": "Lisa",
        "text": "Sure. Would you like a bag?",
        "start": 13.3,
        "end": 15.5,
        "translation_zh": "好的。需要袋子吗？"
      }
    ],
    "vocabulary": [
      {
        "word": "excuse me",
        "phonetic": "/ɪkˈskjuːz miː/",
        "translation_zh": "不好意思，打扰一下",
        "example": "Excuse me, where is the station?",
        "audio": "https://oss.langpod.com/words/excuse-me.mp3"
      },
      {
        "word": "size",
        "phonetic": "/saɪz/",
        "translation_zh": "尺码，大小",
        "example": "What size do you wear?",
        "audio": "https://oss.langpod.com/words/size.mp3"
      },
      {
        "word": "check",
        "phonetic": "/tʃek/",
        "translation_zh": "查看，检查",
        "example": "Let me check the price.",
        "audio": "https://oss.langpod.com/words/check.mp3"
      },
      {
        "word": "medium",
        "phonetic": "/ˈmiːdiəm/",
        "translation_zh": "中号的，中等的",
        "example": "I'd like a medium coffee.",
        "audio": "https://oss.langpod.com/words/medium.mp3"
      },
      {
        "word": "bag",
        "phonetic": "/bæɡ/",
        "translation_zh": "袋子，包",
        "example": "Can I have a paper bag?",
        "audio": "https://oss.langpod.com/words/bag.mp3"
